# MongoDB Atlas in production; a local replica set may be used for development.
DATABASE_URL=mongodb://127.0.0.1/wedding-catalog

# Generate independent high-entropy secrets. Never expose these to the browser.
PAYLOAD_SECRET=replace-with-at-least-32-random-characters
PREVIEW_SECRET=replace-with-at-least-24-random-characters
CRON_SECRET=replace-with-at-least-24-random-characters

# Canonical production origin. Do not include a trailing slash or path.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Stripe test keys locally; configure live keys only in the Vercel production environment.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Cloudflare R2 S3-compatible storage. R2 is required in production so uploads do
# not depend on Vercel's ephemeral filesystem. R2_PUBLIC_URL is the public custom
# media origin and must not include a trailing slash or path.
R2_BUCKET=replace-with-r2-bucket-name
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_ENDPOINT=https://replace-with-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://media.caitbridal.ie
